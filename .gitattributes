# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicitly declare binary files
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.zip binary
*.gz  binary

# Docs
*.md  text diff=markdown
*.txt text

# JS
*.js  text diff=javascript
*.json text

# PHP (for the Drupal module)
*.php text diff=php
*.module text diff=php
*.install text diff=php
*.inc text diff=php
